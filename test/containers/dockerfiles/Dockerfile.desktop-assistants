# ── 豆包专业版 ────────────────────────────────────────────────
RUN ln /bin/sleep /usr/local/bin/doubao && \
    mkdir -p /root/.doubao

# ── Kimi Work ─────────────────────────────────────────────────
RUN ln /bin/sleep /usr/local/bin/Kimi && \
