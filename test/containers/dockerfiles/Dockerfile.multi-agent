FROM ubuntu:22.04

RUN apt-get update && apt-get install -y curl wget python3 python3-pip git && rm -rf /var/lib/apt/lists/*

# Install real Python packages for mixed agent test
RUN pip3 install -i https://pypi.tuna.tsinghua.edu.cn/simple \
    langchain langgraph crewai autogen-agentchat llama-index

# Hardlinks for process detection
RUN for bin in aider claude-code; do ln -f /bin/sleep /usr/local/bin/$bin; done

# Aider config
RUN echo 'model: claude-3' > /root/.aider.conf.yml && \
    echo 'AIDER_MODEL=claude-3' > /root/.env

# Claude Code config
RUN mkdir -p /root/.claude /root/.claude-code && \
    echo '{"model":"claude-sonnet-4"}' > /root/.claude-code/config.json

# Cline
RUN mkdir -p /root/.cline/skills

# Continue
RUN mkdir -p /root/.continue/agents

# VS Code extensions: GitHub Copilot + Cline
RUN mkdir -p /root/.vscode/extensions/github.copilot-1.200.0 && \
    echo '{"name":"copilot","publisher":"GitHub","displayName":"GitHub Copilot","version":"1.200.0","categories":["Machine Learning"],"keywords":["ai","copilot"]}' > /root/.vscode/extensions/github.copilot-1.200.0/package.json

RUN mkdir -p /root/.vscode/extensions/saoudrizwan.claude-dev-3.5.0 && \
    echo '{"name":"claude-dev","publisher":"saoudrizwan","displayName":"Cline","version":"3.5.0","categories":["Other"],"keywords":["ai","agent","cline"],"activationEvents":["onAgent:cline"],"contributes":{"commands":[{"command":"cline.createAgent","title":"Create Agent"}]}}' > /root/.vscode/extensions/saoudrizwan.claude-dev-3.5.0/package.json

# Tabnine
RUN mkdir -p /root/.vscode/extensions/TabNine.tabnine-vscode-3.100.0 && \
    echo '{"name":"tabnine-vscode","publisher":"TabNine","displayName":"Tabnine","version":"3.100.0","categories":["Machine Learning"],"keywords":["tabnine","ai","autocomplete","code"]}' > /root/.vscode/extensions/TabNine.tabnine-vscode-3.100.0/package.json
RUN mkdir -p /root/.tabnine/agent/skills

# CodeBuddy
RUN mkdir -p /root/.vscode/extensions/tencent.codebuddy-1.0.0 && \
    echo '{"name":"codebuddy","publisher":"tencent","displayName":"CodeBuddy","version":"1.0.0","categories":["Machine Learning"],"keywords":["codebuddy","tencent","craft","agent"]}' > /root/.vscode/extensions/tencent.codebuddy-1.0.0/package.json
RUN mkdir -p /root/.codebuddy/skills

# Qoder
RUN mkdir -p /root/.vscode/extensions/alibaba.qoder-1.0.0 && \
    echo '{"name":"qoder","publisher":"alibaba","displayName":"Qoder","version":"1.0.0","categories":["Machine Learning"],"keywords":["qoder","alibaba","agent"]}' > /root/.vscode/extensions/alibaba.qoder-1.0.0/package.json

CMD ["sleep", "infinity"]
