FROM ubuntu:22.04

# =========================================================================
# GitHub Copilot
# =========================================================================
RUN mkdir -p /root/.vscode/extensions/github.copilot-1.200.0
RUN echo '{"name":"copilot","publisher":"GitHub","displayName":"GitHub Copilot","version":"1.200.0","description":"Your AI pair programmer","engines":{"vscode":"^1.80.0"},"categories":["Machine Learning","Other"],"keywords":["ai","copilot","autocomplete"],"contributes":{"commands":[]}}' > /root/.vscode/extensions/github.copilot-1.200.0/package.json

# GitHub Copilot Chat (agent mode)
RUN mkdir -p /root/.vscode/extensions/github.copilot-chat-0.22.0
RUN echo '{"name":"copilot-chat","publisher":"GitHub","displayName":"GitHub Copilot Chat","version":"0.22.0","description":"AI chat with agent mode","engines":{"vscode":"^1.80.0"},"categories":["Chat","Machine Learning"],"keywords":["ai","chat","agent","copilot"],"activationEvents":["onChatParticipant:copilot","onAgent:copilot"],"main":"./dist/agent/extension.js","contributes":{"agent":{"id":"copilot-agent","name":"GitHub Copilot Agent","tools":["read_file","edit","terminal","semantic_search"]},"chatParticipants":[{"id":"copilot","name":"GitHub Copilot"}]}}' > /root/.vscode/extensions/github.copilot-chat-0.22.0/package.json
